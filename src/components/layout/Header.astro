---
import { getCategories } from '../../lib/pocketbase';
let categories = [];
try {
  categories = await getCategories();
} catch (e) {}
---

<header class="bg-cream/90 backdrop-blur-sm sticky top-0 z-50 border-b border-blush/30">
  <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-2xl group-hover:float">🎮</span>
      <span class="font-display text-2xl gradient-text">Lele Gaming</span>
    </a>
    <nav class="hidden md:flex items-center gap-6">
      <a href="/blog" class="font-semibold text-ink hover:text-blush transition-colors">Articles</a>
      {categories.map((cat) => (
        <a href={`/category/${cat.slug}`} class="font-semibold text-ink hover:text-blush transition-colors">
          {cat.icon} {cat.name}
        </a>
      ))}
      <a href="/about" class="font-semibold text-ink hover:text-blush transition-colors">About</a>
    </nav>
    <button class="md:hidden text-2xl" aria-label="Menu">☰</button>
  </div>
</header>
