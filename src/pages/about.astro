---
import Base from '../layouts/Base.astro';
---

<Base title="About" description="Qui est Lele ?">
  <div class="max-w-2xl mx-auto px-4 py-20 text-center">
    <p class="text-6xl mb-6 float">🎮</p>
    <h1 class="font-display text-4xl gradient-text mb-6">Salut, c'est Lele !</h1>
    <p class="text-lg text-ink-light leading-relaxed">
      Gameuse passionnee, je partage ici mes decouvertes, mes reviews et mes coups de coeur. Du RPG au FPS en passant par les jeux indes — avec toujours une touche de paillettes.
    </p>
  </div>
</Base>
