---
import Base from '../layouts/Base.astro';
---

<Base title="Page introuvable">
  <div class="max-w-xl mx-auto px-4 py-32 text-center">
    <p class="text-7xl mb-6 float">🎮</p>
    <h1 class="font-display text-4xl gradient-text mb-4">404 — Game Over</h1>
    <p class="text-ink-light mb-8">Cette page n'existe pas... ou a ete avalee par un boss.</p>
    <a href="/" class="px-6 py-3 bg-blush font-bold rounded-badge text-ink hover:shadow-card transition-all">Retour a l'accueil</a>
  </div>
</Base>
