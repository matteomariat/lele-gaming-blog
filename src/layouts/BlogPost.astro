---
import Base from './Base.astro';
import { formatDate, readingTime, categoryColor } from '../lib/utils';
import type { Article } from '../lib/pocketbase';
import { getCoverUrl } from '../lib/pocketbase';

interface Props {
  article: Article;
}

const { article } = Astro.props;
const category = article.expand?.category;
const coverUrl = getCoverUrl(article);
---

<Base title={article.title} description={article.excerpt} ogImage={coverUrl}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <div class="flex items-center gap-3 mb-4">
      {category && (
        <span class={`px-3 py-1 rounded-badge text-sm font-semibold ${categoryColor(category.slug)}`}>
          {category.icon} {category.name}
        </span>
      )}
      <span class="text-ink-light text-sm">{formatDate(article.publication_date)}</span>
      <span class="text-ink-light text-sm">· {readingTime(article.content)} de lecture</span>
    </div>

    <h1 class="font-display text-4xl md:text-5xl text-ink mb-6 leading-tight">
      {article.title}
    </h1>

    <p class="text-xl text-ink-light mb-8 leading-relaxed">{article.excerpt}</p>

    {article.cover_image && (
      <img
        src={coverUrl}
        alt={article.title}
        class="w-full rounded-card mb-10 shadow-card object-cover aspect-video"
      />
    )}

    <div
      class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-ink prose-a:text-blush"
      set:html={article.content}
    />

    {article.tags?.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-10 pt-8 border-t border-lavender/30">
        {article.tags.map((tag: string) => (
          <a href={`/tag/${tag}`} class="px-3 py-1 rounded-badge bg-lavender/20 text-ink text-sm font-semibold hover:bg-lavender/40 transition-colors">
            #{tag}
          </a>
        ))}
      </div>
    )}
  </article>
</Base>
